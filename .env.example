# ─────────────────────────────────────────────────────────
# TODO LO QUE CAMBIA ENTRE TIENDA Y TIENDA VIVE AQUÍ.
# Copia este archivo como ".env.local" y llena los valores
# para CADA tienda nueva. El código nunca se toca.
# ─────────────────────────────────────────────────────────

# --- Identidad de la tienda ---
STORE_NAME="Nombre de la Tienda"
STORE_SLUG="nombre-tienda"          # sin espacios/acentos, se usa para el bucket de imágenes
STORE_SLOGAN="Lo que necesitas, más cerca de ti."
STORE_LOGO_PATH="/logo.png"         # archivo dentro de /public
STORE_COLOR_PRIMARY="#0f766e"
STORE_COLOR_ACCENT="#f59e0b"

# --- Tema visual (opcional) — ver temas/CATALOGO-DE-TEMAS.md para 5 combinaciones listas ---
STORE_HEADER_GRADIENT=""     # ej: "linear-gradient(135deg, #1a3d2b 0%, #2d6a4f 100%)". Vacío = header de color sólido (STORE_COLOR_PRIMARY)
STORE_FONT_TITULO=""         # ej: "'Cormorant Garamond', serif". Vacío = hereda la fuente del cuerpo
STORE_FONT_BODY=""           # ej: "'Inter', sans-serif". Vacío = fuente del sistema
STORE_FONT_GOOGLE_URL=""     # link completo de Google Fonts que carga las fuentes de arriba

# --- Contacto / footer ---
STORE_WHATSAPP="53XXXXXXXX"          # sin '+' ni espacios
STORE_EMAIL="correo@ejemplo.com"
STORE_FACEBOOK="https://facebook.com/tu-pagina"
STORE_ADDRESS=""
STORE_SCHEDULE="Lun-Sáb: 8:30 AM - 4:00 PM"

# --- Funcionalidades opcionales ---
STORE_SHOW_EXCHANGE_RATE="true"     # "true" para mostrar tasa USD->CUP, "false" para ocultarla

# Para tiendas que NO manejan USD en absoluto (todo en CUP directo, sin
# tasa de por medio). El precio que cargues en el admin será el valor en
# CUP tal cual. Es EXCLUYENTE con STORE_SHOW_EXCHANGE_RATE: si activas
# esta, deja la de arriba en "false".
STORE_SOLO_CUP="false"

# --- Categorías (formato JSON, un array de {id, nombre}) ---
STORE_CATEGORIES='[{"id":"electronica","nombre":"Electrónica y Tecnología"},{"id":"belleza","nombre":"Cuidado Personal y Belleza"},{"id":"ropa","nombre":"Ropa y Calzado"},{"id":"hogar","nombre":"Hogar y Limpieza"},{"id":"automovil","nombre":"Automóvil y Herramientas"},{"id":"regalos","nombre":"Regalos Fiesta y Varios"},{"id":"salud","nombre":"Salud y Farmacia Básica"}]'

# --- Supabase: UN PROYECTO SUPABASE POR CADA TIENDA (no compartir) ---
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY="anon-key-aqui"                  # clave pública "anon"
SUPABASE_SERVICE_ROLE="service-role-key-aqui" # clave privada, NUNCA en el frontend
SUPABASE_BUCKET="productos_images"

# --- Panel de administración ---
ADMIN_PASSWORD="cambia-esta-clave"
ADMIN_TOKEN="genera-un-token-largo-aleatorio"

PORT=3000
